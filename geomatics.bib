@article{Piekut2019segregation,
author = {Piekut, Aneta and Pryce, Gwilym and van Gent, Wouter},
title = {Segregation in the Twenty First Century: Processes, Complexities and Future Directions},
journal = {Tijdschrift voor Economische en Sociale Geografie},
volume = {110},
number = {3},
pages = {225-234},
keywords = {Segregation, measurement, methods, inequality, migration, spatial analysis},
doi = {https://doi.org/10.1111/tesg.12355},
url = {https://onlinelibrary.wiley.com/doi/abs/10.1111/tesg.12355},
eprint = {https://onlinelibrary.wiley.com/doi/pdf/10.1111/tesg.12355},
abstract = {Abstract Economic inequality, international migration and urban transformation have generated fresh interest in segregation and given new social significance to questions of socio-spatial separation and interaction. At the same time, advances in data, methods and theory are opening up new avenues of inquiry that push the focus beyond simple measures of unevenness of residential patterns towards more nuanced analysis of spatial asymmetry, structure and scale. There is also a drive towards considering spaces and activities outside the neighbourhood, bringing new richness to our understanding of how various social groups interact in the various aspects of their lives. These processes and complexities form the backdrop for our special issue and we reflect on the implications for future priorities in research on segregation in the twenty first century.},
year = {2019}
}


